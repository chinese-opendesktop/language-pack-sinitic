"#   %l              Like %L but with description\n"
"#   %N              Name\n"
"#   %n              Like %N but with description\n"
"#   %S              Content subtype\n"
"#   %s              Like %S but with description\n"
"#   %T              Content type\n"
"#   %t              Like %T but with description\n"
