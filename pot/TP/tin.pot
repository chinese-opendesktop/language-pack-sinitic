"#   %(formatstr)D   Date, formatstr gets passed to my_strftime()\n"
"#   %F              From, name and/or address according to show_author\n"
"#   %I              Initials\n"
"#   %L              Line count\n"
"#   %M              Message-ID\n"
"#   %m              Article marks\n"
"#   %n              Number, linenumber on screen\n"
"#   %R              Count, number of responses in thread\n"
